diff --git a/Insights-API/src/main/java/dev/frankheijden/insights/api/concurrent/containers/UnloadedChunkContainer.java b/Insights-API/src/main/java/dev/frankheijden/insights/api/concurrent/containers/UnloadedChunkContainer.java
index 37c4e84..d5c2523 100644
--- a/Insights-API/src/main/java/dev/frankheijden/insights/api/concurrent/containers/UnloadedChunkContainer.java
+++ b/Insights-API/src/main/java/dev/frankheijden/insights/api/concurrent/containers/UnloadedChunkContainer.java
@@ -29,7 +29,13 @@ public class UnloadedChunkContainer extends ChunkContainer {
 
     @Override
     public void getChunkSections(Consumer<@Nullable ChunkSection> sectionConsumer) {
-        nms.getUnloadedChunkSections(world, chunkX, chunkZ, sectionConsumer);
+        if (org.bukkit.Bukkit.isOwnedByCurrentRegion(world, chunkX, chunkZ)) {
+            nms.getUnloadedChunkSections(world, chunkX, chunkZ, sectionConsumer);
+        } else {
+            org.bukkit.Bukkit.getRegionScheduler().run(dev.frankheijden.insights.api.InsightsPlugin.getInstance(), world, chunkX, chunkZ, (scheduledTask) -> {
+                nms.getUnloadedChunkSections(world, chunkX, chunkZ, sectionConsumer);
+            });
+        }
     }
 
     @Override
